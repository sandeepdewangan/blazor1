@page "/servers/{id:int}"

<h3>Edit Server - @Id</h3>

@if(server != null)
{
    <p> ☑️ @server.Name </p>
    <p> ☑️ @server.City </p>
    <p> ☑️ @(server.IsOnline?"Online":"Offline") </p>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private Server? server;

    // lifecycle method
    protected override void OnParametersSet()
    {
        server = ServerRepo.GetServerById(this.Id);
    }

}

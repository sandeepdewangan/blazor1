@page "/servers"

<h3><img src="@($"/images/server.png")" height="50" /> Servers</h3>
<hr/>

@foreach(var city in cities)
{
    <button class="btn btn-info m-1">@city</button>
}

<hr />

<ul>
    @foreach(var server in servers)
    {
        <li>
            @server.Name in @server.City is 
            <span style="color:@((server.IsOnline?"green":"red"))">
                   @(server.IsOnline ? "online" : "offline")
            </span>
            <a href="/servers/@server.ServerId" class="text-decoration-none">Edit</a>
        </li>
    }
</ul>

@code {
    private List<Server> servers = ServerRepo.GetServersByCity("raipur");
    private List<string> cities = CityRepo.GetCities();
}

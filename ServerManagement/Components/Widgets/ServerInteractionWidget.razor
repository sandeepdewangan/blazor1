<h4>Server Interaction</h4>

@if (server != null)
{
    <div>
        @server.Name is in @server.City is @(server.IsOnline ? "Online" : "Offline")
        <button class="btn btn-primary" @onclick="ChangeStatus">Turn on/off</button>
    </div>
}



@code {
    private Server? server { get; set; } = new Server { Name = "NIC Raipur", City = "Raipur" };



    private void ChangeStatus()
    {
        if (server != null)
        {
            server.IsOnline = !server.IsOnline;
        }
    }
}
